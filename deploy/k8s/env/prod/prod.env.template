# Prod environment values (minimum required for deployment)
# Copy to prod.env and replace all placeholder values.

NAMESPACE=healthcare-prod
KUBE_CONTEXT=<prod-kube-context>

SERVICEBUS_NAMESPACE=hpe-prod-sb.servicebus.windows.net
EVENTHUB_NAMESPACE=hpe-prod-eh.servicebus.windows.net
KEY_VAULT_URL=https://hpe-prod-kv.vault.azure.net/
FHIR_INTEGRATION_BASE_URL=https://hpe-prod-fhir.azurehealthcareapis.com
SERVICE_BUS_INTEGRATION_BASE_URL=https://svc-event-messaging.healthcare-prod.svc.cluster.local
TELECONSULT_JOIN_BASE_URL=https://<prod-teleconsult-public-host>/session
ACS_IDENTITY_CONNECTION_STRING=endpoint=https://<prod-acs-resource>.communication.azure.com/;accesskey=<prod-acs-access-key>
OTEL_OTLP_ENDPOINT=http://otel-collector.monitoring.svc.cluster.local:4317
OAUTH2_ISSUER=https://login.microsoftonline.com/<prod-tenant-id>/v2.0
OAUTH2_AUDIENCE=api://<prod-app-id-uri>
OAUTH2_JWK_SET_URI=https://login.microsoftonline.com/<prod-tenant-id>/discovery/v2.0/keys
AZURE_SQL_JDBC_URL=jdbc:sqlserver://<prod-sql-server>.database.windows.net:1433;database=<prod-shared-db>;encrypt=true;hostNameInCertificate=*.database.windows.net;loginTimeout=30;
AZURE_SQL_USERNAME=<prod-sql-user>
AZURE_SQL_PASSWORD=<prod-sql-password-or-token>
AZURE_MANAGED_IDENTITY_CLIENT_ID=<prod-user-assigned-managed-identity-client-id>
