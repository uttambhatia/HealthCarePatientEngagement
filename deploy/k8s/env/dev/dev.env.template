# Dev environment values (minimum required for deployment)
# Copy to dev.env and replace all placeholder values.
# Optional bootstrap path:
#   .\deploy\k8s\env\dev\bootstrap-dev-azure.ps1 -OAuth2Audience <audience>
# This creates the minimum Azure dev resources, writes dev.env, and renders
# platform-secrets.dev.generated.yaml for use with apply-dev.ps1 -EnvFile.

NAMESPACE=healthcare-dev
KUBE_CONTEXT=<dev-kube-context>

# Hub-spoke network and regional DR model
PRIMARY_REGION=<dev-primary-region>
SECONDARY_REGION=<dev-secondary-region>
HUB_VNET_NAME=<dev-hub-vnet-name>
PRIMARY_VNET_NAME=<dev-primary-vnet-name>
SECONDARY_VNET_NAME=<dev-secondary-vnet-name>
TRAFFIC_MANAGER_PROFILE_NAME=<dev-traffic-manager-profile-name>
TRAFFIC_MANAGER_DNS_NAME=<dev-traffic-manager-dns-name>
FRONT_DOOR_PROFILE_NAME=<dev-front-door-profile-name>
PRIMARY_FRONT_DOOR_PROFILE_NAME=<dev-front-door-primary-profile-name>
PRIMARY_FRONT_DOOR_ENDPOINT_HOST=<dev-front-door-primary-hostname>
SECONDARY_FRONT_DOOR_PROFILE_NAME=<dev-front-door-secondary-profile-name>
SECONDARY_FRONT_DOOR_ENDPOINT_HOST=<dev-front-door-secondary-hostname>
PRIMARY_AKS_CLUSTER_NAME=<dev-primary-aks-cluster-name>
SECONDARY_AKS_CLUSTER_NAME=<dev-secondary-aks-cluster-name>
PRIMARY_APP_SERVICE_NAME=<dev-primary-ui-appservice-name>
SECONDARY_APP_SERVICE_NAME=<dev-secondary-ui-appservice-name>

SERVICEBUS_NAMESPACE=hpe-dev-sb.servicebus.windows.net
EVENTHUB_NAMESPACE=hpe-dev-eh.servicebus.windows.net
KEY_VAULT_URL=https://hpe-dev-kv.vault.azure.net/
FHIR_INTEGRATION_BASE_URL=https://hpe-dev-fhir.azurehealthcareapis.com
SERVICE_BUS_INTEGRATION_BASE_URL=https://svc-event-messaging.healthcare-dev.svc.cluster.local
# Set per environment. Use a real externally reachable teleconsult host; do not use <...> placeholders.
TELECONSULT_JOIN_BASE_URL=https://teleconsult-dev.contoso.com/session
ACS_IDENTITY_CONNECTION_STRING=endpoint=https://<dev-acs-resource>.communication.azure.com/;accesskey=<dev-acs-access-key>
OTEL_OTLP_ENDPOINT=http://otel-collector.monitoring.svc.cluster.local:4317
OAUTH2_ISSUER=https://login.microsoftonline.com/<dev-tenant-id>/v2.0
OAUTH2_AUDIENCE=api://<dev-app-id-uri>
OAUTH2_JWK_SET_URI=https://login.microsoftonline.com/<dev-tenant-id>/discovery/v2.0/keys
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<dev-storage-account>;AccountKey=<dev-storage-account-key>;EndpointSuffix=core.windows.net
PATIENT_IDPROOF_CONTAINER=patient-id-proofs
PROFILE_PHOTO_CONTAINER=user-profile-photos
ENTRA_API_APP_ID=<dev-api-app-id>
ENTRA_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
ENTRA_PATIENT_GROUP_NAME=HCPE-PATIENT
ENTRA_PATIENT_ROLE_VALUE=PATIENT
ENTRA_INVITE_REDIRECT_URL=https://myapplications.microsoft.com
AZURE_SQL_JDBC_URL=jdbc:sqlserver://<dev-sql-server>.database.windows.net:1433;database=<dev-shared-db>;encrypt=true;hostNameInCertificate=*.database.windows.net;loginTimeout=30;
AZURE_SQL_USERNAME=<dev-sql-user>
AZURE_SQL_PASSWORD=<dev-sql-password-or-token>
AZURE_MANAGED_IDENTITY_CLIENT_ID=<dev-user-assigned-managed-identity-client-id>
