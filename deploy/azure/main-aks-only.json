      "type": "string",
      "defaultValue": "centralindia"
    },
    "environment": {
      "type": "string",
      "defaultValue": "dev"
    },
    "aksClusterName": {
      "type": "string",
      "defaultValue": "[format('aks-hpe-{0}', parameters('environment'))]"
    },
    "aksNodeCount": {
      "type": "int",
      "defaultValue": 3
    },
    "aksNodeVmSize": {
      "type": "string",
      "defaultValue": "Standard_B2s_v2"
    },
    "aksVersion": {
      "type": "string",
      "defaultValue": "1.34.8"
    }
  },
  "variables": {
    "primaryVNetName": "[format('hpe-primary-vnet-{0}', parameters('environment'))]",
    "primaryApplicationSubnetName": "application-subnet"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "primary-aks-cluster",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "location": {
            "value": "[parameters('location')]"
          },
          "environment": {
            "value": "[parameters('environment')]"
          },
          "aksClusterName": {
            "value": "[parameters('aksClusterName')]"
          },
          "aksNodeCount": {
            "value": "[parameters('aksNodeCount')]"
          },
          "aksNodeVmSize": {
            "value": "[parameters('aksNodeVmSize')]"
          },
          "aksVersion": {
            "value": "[parameters('aksVersion')]"
          },
          "primaryApplicationSubnetId": {
            "value": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('primaryVNetName'), variables('primaryApplicationSubnetName'))]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.44.1.10279",
              "templateHash": "3589545738085858608"
            }
          },
          "parameters": {
            "location": {
              "type": "string",
              "defaultValue": "[resourceGroup().location]"
            },
            "environment": {
              "type": "string",
              "defaultValue": "dev"
            },
            "aksClusterName": {
              "type": "string",
              "defaultValue": "[format('aks-hpe-{0}', parameters('environment'))]"
            },
            "aksNodeCount": {
              "type": "int",
              "defaultValue": 3
            },
            "aksNodeVmSize": {
              "type": "string",
              "defaultValue": "Standard_B2s_v2"
            },
            "aksVersion": {
              "type": "string",
              "defaultValue": "1.34.8"
            },
            "primaryApplicationSubnetId": {
              "type": "string"
            }
          },
          "resources": [
            {
              "type": "Microsoft.ContainerService/managedClusters",
              "apiVersion": "2024-02-01",
              "name": "[parameters('aksClusterName')]",
              "location": "[parameters('location')]",
              "identity": {
                "type": "SystemAssigned"
              },
              "sku": {
                "name": "Base",
                "tier": "Standard"
              },
              "properties": {
                "kubernetesVersion": "[parameters('aksVersion')]",
                "dnsPrefix": "[format('{0}-dns', parameters('aksClusterName'))]",
                "agentPoolProfiles": [
                  {
                    "name": "nodepool1",
                    "count": "[parameters('aksNodeCount')]",
                    "vmSize": "[parameters('aksNodeVmSize')]",
                    "mode": "System",
                    "osType": "Linux",
                    "osDiskSizeGB": 128,
                    "vnetSubnetID": "[parameters('primaryApplicationSubnetId')]",
                    "enableNodePublicIP": false,
                    "nodeLabels": {
                      "workload": "general"
                    }
                  }
                ],
                "networkProfile": {
                  "networkPlugin": "kubenet",
                  "networkPolicy": "calico",
                  "serviceCidrs": [
                    "10.10.0.0/16"
                  ],
                  "dnsServiceIP": "10.10.0.10",
                  "outboundType": "loadBalancer",
                  "loadBalancerProfile": {
                    "managedOutboundIPs": {
                      "count": 1
                    }
                  }
                },
                "addonProfiles": {
                  "httpApplicationRouting": {
                    "enabled": false
                  },
                  "omsagent": {
                    "enabled": false
                  }
                },
                "apiServerAccessProfile": {
                  "enablePrivateCluster": false,
                  "authorizedIPRanges": [
                    "0.0.0.0/0"
                  ]
                },
                "autoUpgradeProfile": {
                  "upgradeChannel": "stable"
                }
              }
            }
          ],
          "outputs": {
            "aksClusterId": {
              "type": "string",
              "metadata": {
                "description": "The AKS Cluster ID"
              },
              "value": "[resourceId('Microsoft.ContainerService/managedClusters', parameters('aksClusterName'))]"
            },
            "aksClusterName": {
              "type": "string",
              "metadata": {
                "description": "The AKS Cluster Name"
              },
              "value": "[parameters('aksClusterName')]"
            },
            "aksClusterFqdn": {
              "type": "string",
              "metadata": {
                "description": "The AKS Cluster FQDN"
              },
              "value": "[reference(resourceId('Microsoft.ContainerService/managedClusters', parameters('aksClusterName')), '2024-02-01').fqdn]"
            },
            "aksKubeletIdentity": {
              "type": "object",
              "metadata": {
                "description": "The AKS Cluster Kubelet Identity"
              },
              "value": "[reference(resourceId('Microsoft.ContainerService/managedClusters', parameters('aksClusterName')), '2024-02-01').identityProfile.kubeletidentity]"
            },
            "aksNodeResourceGroup": {
              "type": "string",
              "metadata": {
                "description": "The AKS Node Resource Group"
              },
              "value": "[reference(resourceId('Microsoft.ContainerService/managedClusters', parameters('aksClusterName')), '2024-02-01').nodeResourceGroup]"
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "aksClusterId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'primary-aks-cluster'), '2025-04-01').outputs.aksClusterId.value]"
    },
    "aksClusterName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'primary-aks-cluster'), '2025-04-01').outputs.aksClusterName.value]"
    },
    "aksClusterFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'primary-aks-cluster'), '2025-04-01').outputs.aksClusterFqdn.value]"
    },
    "deploymentStatus": {
      "type": "string",
      "value": "AKS cluster deployed successfully in primary application subnet"
    }
  }
}