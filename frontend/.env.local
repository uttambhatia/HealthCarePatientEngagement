# Local frontend runtime configuration
# Fill only VITE_OIDC_CLIENT_ID from your Azure App Registration.
# If Vite starts on a different port, update VITE_OIDC_REDIRECT_URI accordingly.

VITE_API_BASE_URL=http://localhost:8080

# Azure AD / OIDC (Authorization Code + PKCE)
VITE_OIDC_CLIENT_ID=
VITE_OIDC_AUTHORIZATION_ENDPOINT=https://login.microsoftonline.com/fb4ebd65-b78b-42a4-b64c-26f5692e3c7c/oauth2/v2.0/authorize
VITE_OIDC_TOKEN_ENDPOINT=https://login.microsoftonline.com/fb4ebd65-b78b-42a4-b64c-26f5692e3c7c/oauth2/v2.0/token
VITE_OIDC_LOGOUT_ENDPOINT=https://login.microsoftonline.com/fb4ebd65-b78b-42a4-b64c-26f5692e3c7c/oauth2/v2.0/logout
VITE_OIDC_REDIRECT_URI=http://localhost:5173
VITE_OIDC_SCOPE=openid profile email api://<client-id>/.default
VITE_BYPASS_AUTH=true

# Optional realtime transport endpoints
# VITE_EVENTS_WS_URL=ws://localhost:8080/ws/events
# VITE_EVENTS_SSE_URL=http://localhost:8080/api/events/stream
