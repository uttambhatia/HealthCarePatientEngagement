# Local frontend runtime configuration
# Fill only VITE_OIDC_CLIENT_ID from your Azure App Registration.
# If Vite starts on a different port, update VITE_OIDC_REDIRECT_URI accordingly.

VITE_API_BASE_URL=http://localhost:8080

# Azure AD / OIDC (Authorization Code + PKCE)
VITE_OIDC_CLIENT_ID=526100bc-f963-4edd-8890-9011252bb554
VITE_OIDC_AUTHORIZATION_ENDPOINT=https://login.microsoftonline.com/65087c47-0017-4258-8086-72832006d566/oauth2/v2.0/authorize
VITE_OIDC_TOKEN_ENDPOINT=https://login.microsoftonline.com/65087c47-0017-4258-8086-72832006d566/oauth2/v2.0/token
VITE_OIDC_LOGOUT_ENDPOINT=https://login.microsoftonline.com/65087c47-0017-4258-8086-72832006d566/oauth2/v2.0/logout
VITE_OIDC_REDIRECT_URI=http://localhost:5173
VITE_OIDC_SCOPE=openid profile api://65087c47-0017-4258-8086-72832006d566/hpe-devx-api/access_as_user
VITE_BYPASS_AUTH=true

# Optional realtime transport endpoints
# VITE_EVENTS_WS_URL=ws://localhost:8080/ws/events
# VITE_EVENTS_SSE_URL=http://localhost:8080/api/events/stream
