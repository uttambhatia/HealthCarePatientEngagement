# Copy this file to .env.local and fill values for your Azure Entra app registrations.
# cp .env.example .env.local

# Gateway URL (used by apiClient for business APIs)
VITE_API_BASE_URL=http://localhost:8080

# OIDC (Authorization Code + PKCE)
# Replace <tenant-id> with your Entra tenant id and <spa-client-id> with the SPA app registration id.
VITE_OIDC_CLIENT_ID=<spa-client-id>
VITE_OIDC_AUTHORIZATION_ENDPOINT=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/authorize
VITE_OIDC_TOKEN_ENDPOINT=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token
VITE_OIDC_LOGOUT_ENDPOINT=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/logout
VITE_OIDC_REDIRECT_URI=http://localhost:5173
# Request the delegated API scope so the access token carries backend app-role claims.
VITE_OIDC_SCOPE=openid profile api://<tenant-id>/hpe-devx-api/access_as_user

# Optional realtime endpoints
# VITE_EVENTS_WS_URL=ws://localhost:8080/ws/events
# VITE_EVENTS_SSE_URL=http://localhost:8080/api/events/stream