# Copy this file to .env.local and fill values for your Azure AD app registration\n# cp .env.example .env.local\n\n# Gateway URL (used by apiClient for business APIs)\nVITE_API_BASE_URL=http://localhost:8080\n\n# OIDC (Authorization Code + PKCE)\n# Replace <tenant-id> and <client-id> with your Azure app registration values\nVITE_OIDC_CLIENT_ID=<client-id>\nVITE_OIDC_AUTHORIZATION_ENDPOINT=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/authorize\nVITE_OIDC_TOKEN_ENDPOINT=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token\nVITE_OIDC_LOGOUT_ENDPOINT=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/logout\nVITE_OIDC_REDIRECT_URI=http://localhost:5173\nVITE_OIDC_SCOPE=openid profile email api://<client-id>/.default\n\n# Optional realtime endpoints\n# VITE_EVENTS_WS_URL=ws://localhost:8080/ws/events\n# VITE_EVENTS_SSE_URL=http://localhost:8080/api/events/stream\n